{
  "name": "specsync",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.6",
  "publisher": "logi-cmd",
  "repository": {
    "type": "git",
    "url": "https://github.com/logi-cmd/specsync"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "api",
    "documentation",
    "spec",
    "openapi",
    "swagger",
    "sync"
  ],
  "activationEvents": [
    "onCommand:specsync.showPanel",
    "onCommand:specsync.scanSync",
    "onView:specsync.view",
    "workspaceContains:**/*.spec.md",
    "workspaceContains:**/spec/*.md"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "specsync.showPanel",
        "title": "%command.showPanel%",
        "category": "SpecSync"
      },
      {
        "command": "specsync.scanSync",
        "title": "%command.scanSync%",
        "category": "SpecSync"
      },
      {
        "command": "specsync.showWelcome",
        "title": "%command.showWelcome%",
        "category": "SpecSync"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "specsync.view",
          "name": "%view.name%",
          "when": "workspaceHasSpecFiles"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "specsync.scanSync",
          "when": "view == specsync.view",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "specsync.scanSync",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "specsync.scanSync",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "SpecSync",
      "properties": {
        "specsync.specPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.spec.md",
            "**/spec/*.md"
          ],
          "description": "%config.specPatterns.description%"
        },
        "specsync.autoScan": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoScan.description%"
        },
        "specsync.autoScanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoScanOnSave.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "typescript": "^4.9.4",
    "yaml": "^2.3.0"
  }
}
